{
    "manifest_version": 3,
    "name": "SpeedRoll",
    "version": "1.0",
    "description": "Controle de velocidade extendido para a Crunchyroll",
    "host_permissions": ["*://*.crunchyroll.com/*"],
    "content_scripts":[
        {
            "matches": ["*://*.crunchyroll.com/*"],
            "js": ["content.js"],
            "css": ["style.css"],
            "run_at": "document_start"
        }
    ],
    "icons": {
        "128": "icon.png"
    }
}